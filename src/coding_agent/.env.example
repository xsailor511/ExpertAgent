# === LLM API 密钥（按需配置）===
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
ZHIPUAI_API_KEY=xxx

# === 默认模型配置 ===
# 支持: openai:gpt-4o, anthropic:claude-3-5-sonnet, litellm:*, zhipu:glm-4
CODING_AGENT_MODEL=openai:gpt-4o
CODING_AGENT_BASE_URL=
CODING_AGENT_API_KEY=

# === 工作目录 ===
CODING_AGENT_WORKDIR=.

# === 权限模式 ===
# ask     - 每次操作前询问 (默认)
# auto    - 自动批准所有操作 (危险, 仅用于沙箱)
# readonly- 只读模式
CODING_AGENT_PERMISSION=ask

# === 沙箱配置 ===
CODING_AGENT_SANDBOX=local
# CODING_AGENT_SANDBOX=docker
# CODING_AGENT_DOCKER_IMAGE=python:3.12-slim

# === 日志 ===
CODING_AGENT_LOG_LEVEL=INFO
CODING_AGENT_LOG_FILE=

# === 上下文窗口 ===
CODING_AGENT_MAX_TOKENS=200000
CODING_AGENT_MAX_HISTORY=50
